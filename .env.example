# ─── Django ───────────────────────────────────────────────────────────────────
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=_z$70o#l+4_0nm4+=6hk3o0_o@ps-@jc#joj!i_&dq=-q$za%6

# "True" apenas em desenvolvimento local — NUNCA em produção
DEBUG=True

# Hosts permitidos, separados por vírgula
# Em produção: seu domínio Railway (ex: minha-api.up.railway.app)
ALLOWED_HOSTS=127.0.0.1,localhost

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Desenvolvimento (SQLite): deixe vazio — definido automaticamente em development.py
# Produção (PostgreSQL Railway): copie do painel Railway → Variables → DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origens do frontend permitidas, separadas por vírgula (usado quando DEBUG=False)
# Em produção: URL do seu app Vercel (ex: https://finance-control.vercel.app)
CORS_ALLOWED_ORIGINS=http://localhost:5173 || fincontrol.devreloaded.com.br

# ─── Django Settings Module ───────────────────────────────────────────────────
# Desenvolvimento local: backend.settings.development
# Produção Railway:      backend.settings.production  (wsgi.py já define como padrão)
DJANGO_SETTINGS_MODULE=backend.settings.development
