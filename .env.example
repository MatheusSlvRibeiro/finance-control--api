# Gere uma chave segura com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# True apenas em desenvolvimento local
DEBUG=True

# Separados por vírgula
ALLOWED_HOSTS=127.0.0.1,localhost

# Separados por vírgula — usado apenas quando DEBUG=False
CORS_ALLOWED_ORIGINS=http://localhost:5173
